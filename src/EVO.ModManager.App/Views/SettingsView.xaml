<UserControl x:Class="EVO.ModManager.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EVO.ModManager.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <ScrollViewer>
        <StackPanel Margin="16">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,16"/>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Game Paths" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GamePath}" FontSize="12"
                                   Margin="8,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ACE Folder:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AcePath}" FontSize="12"
                                   Margin="8,0,0,4"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Editor SDK:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SdkStatus}" FontSize="12"
                                   TextWrapping="Wrap" Margin="8,0,0,4"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="LiveryLab:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <TextBlock Text="{Binding LiveryLabStatus}" FontSize="12" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                            <Button Command="{Binding DownloadLiveryLabCommand}"
                                    Content="Download" Margin="8,0,0,0"
                                    FontSize="12" Padding="8,2"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"
                    CornerRadius="6" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Storage Locations" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <TextBlock Text="Mods installed to external drives use symbolic links. The actual mod files stay on the storage drive, and the game sees them as if they were in the mods folder."
                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding StorageLocations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource BgDarkBrush}" CornerRadius="4"
                                        Padding="12" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                                <Border Background="{StaticResource SuccessBrush}"
                                                        CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                                        Visibility="{Binding IsDefault, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="Default" FontSize="10" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Path}" FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding FreeSpace, StringFormat='Free: {0}'}"
                                                       FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Set Default" FontSize="11"
                                                Padding="8,4" Margin="4,0"
                                                Command="{Binding DataContext.SetDefaultLocationCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                        <Button Grid.Column="2" Content="Remove" FontSize="11"
                                                Padding="8,4" Margin="4,0"
                                                Background="{StaticResource DangerBrush}"
                                                Command="{Binding DataContext.RemoveLocationCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="0,12" Opacity="0.3"/>

                    <TextBlock Text="Add New Storage Location" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewLocationName, Mode=TwoWay}"
                                 Margin="8,0,0,4"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewLocationPath, Mode=TwoWay}"
                                 Margin="8,0,0,4"/>
                        <Button Grid.Row="1" Grid.Column="2" Command="{Binding BrowseLocationCommand}"
                                Content="Browse..." Margin="4,0,0,4" Padding="8,2"/>

                        <Button Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                Command="{Binding AddLocationCommand}"
                                Content="Add Location" Margin="8,4,0,0"
                                Style="{StaticResource AccentButton}" HorizontalAlignment="Left"/>
                    </Grid>

                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="{StaticResource SuccessBrush}" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
