<UserControl x:Class="EVO.ModManager.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EVO.ModManager.App.Converters"
             Background="Transparent" Foreground="#DDDDDD">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <ScrollViewer Background="Transparent" BorderThickness="0">
        <StackPanel Margin="20">
            <TextBlock Text="Settings" FontSize="18" FontWeight="Bold" Foreground="#E94560" Margin="0,0,0,16"/>

            <Border Background="#16163A" BorderBrush="#1E1E3E" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Game Paths" FontSize="14" FontWeight="SemiBold" Foreground="#DDDDDD" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GamePath}" FontSize="12" Foreground="#BBBBCC" Margin="8,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ACE Folder:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AcePath}" FontSize="12" Foreground="#BBBBCC" Margin="8,0,0,4"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Editor SDK:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SdkStatus}" FontSize="12" Foreground="#BBBBCC" TextWrapping="Wrap" Margin="8,0,0,4"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="LiveryLab:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0">
                            <TextBlock Text="{Binding LiveryLabStatus}" FontSize="12" Foreground="#BBBBCC" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <Button Command="{Binding DownloadLiveryLabCommand}" Content="_Download"
                                    Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A4A"
                                    BorderThickness="1" Padding="8,3" FontSize="11" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="#16163A" BorderBrush="#1E1E3E" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Storage Locations" FontSize="14" FontWeight="SemiBold" Foreground="#DDDDDD" Margin="0,0,0,6"/>
                    <TextBlock Text="External drives use symbolic links." FontSize="12" Foreground="#6666AA" Margin="0,0,0,12"/>

                    <ItemsControl ItemsSource="{Binding StorageLocations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A44" CornerRadius="4" Padding="12" Margin="0,0,0,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13" Foreground="#DDDDDD"/>
                                                <Border Background="#2ECC71" CornerRadius="2" Padding="3,1" Margin="6,0,0,0"
                                                        Visibility="{Binding IsDefault, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="Default" FontSize="8" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="#6666AA" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding FreeSpace, StringFormat=Free: {0}}" FontSize="11" Foreground="#6666AA"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Set Default" FontSize="11"
                                                Padding="6,3" Margin="4,0"
                                                Background="#1A1A3E" Foreground="#CCCCCC" BorderBrush="#2A2A4A"
                                                BorderThickness="1"
                                                Command="{Binding DataContext.SetDefaultLocationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                        <Button Grid.Column="2" Content="Remove" FontSize="11"
                                                Padding="6,3" Margin="4,0"
                                                Background="#2A1A1A" Foreground="#E06060" BorderBrush="#3A2A2A"
                                                BorderThickness="1"
                                                Command="{Binding DataContext.RemoveLocationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="#1E1E3E" Margin="0,10,0,10" Opacity="0.5"/>

                    <TextBlock Text="Add New Storage" FontSize="13" FontWeight="SemiBold" Foreground="#DDDDDD" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewLocationName, Mode=TwoWay}"
                                 Background="#1A1A3E" Foreground="#DDDDDD" BorderBrush="#2A2A4A"
                                 BorderThickness="1" Padding="6,3" FontSize="12" Margin="6,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewLocationPath, Mode=TwoWay}"
                                 Background="#1A1A3E" Foreground="#DDDDDD" BorderBrush="#2A2A4A"
                                 BorderThickness="1" Padding="6,3" FontSize="12" Margin="6,0,0,4"/>
                        <Button Grid.Row="1" Grid.Column="2" Command="{Binding BrowseLocationCommand}"
                                Content="_Browse..." Background="#1E1E3E" Foreground="#CCCCCC"
                                BorderBrush="#2A2A4A" BorderThickness="1" Padding="8,3" FontSize="11" Margin="4,0,0,4"/>
                        <Button Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                Command="{Binding AddLocationCommand}" Content="_Add Location"
                                Background="#E94560" Foreground="White" BorderThickness="0"
                                Padding="10,5" FontSize="12" FontWeight="Bold" HorizontalAlignment="Left" Margin="6,4,0,0"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#2ECC71" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#16163A" BorderBrush="#1E1E3E" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Backup &amp; Restore" FontSize="14" FontWeight="SemiBold" Foreground="#DDDDDD" Margin="0,0,0,6"/>
                    <TextBlock Text="Create a full backup of all installed mods as a ZIP archive, or restore from a previously created backup file." FontSize="12" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Command="{Binding BackupAllCommand}" Content="_Backup All Mods"
                                Background="#E94560" Foreground="White" BorderThickness="0"
                                Padding="12,6" FontSize="12" FontWeight="Bold" Margin="0,0,8,0"/>
                        <Button Command="{Binding RestoreBackupCommand}" Content="_Restore from Backup"
                                Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A4A"
                                BorderThickness="1" Padding="12,6" FontSize="12"/>
                    </StackPanel>

                    <TextBlock Text="{Binding BackupStatus}" FontSize="12" Foreground="#CCCCCC" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#16163A" BorderBrush="#1E1E3E" BorderThickness="1"
                    CornerRadius="8" Padding="16" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Mod Collections" FontSize="14" FontWeight="SemiBold" Foreground="#DDDDDD" Margin="0,0,0,6"/>
                    <TextBlock Text="Export a JSON list of installed mods or import a collection to see which mods are available, installed, or missing." FontSize="12" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Command="{Binding ExportCollectionCommand}" Content="_Export Collection (JSON)"
                                Background="#E94560" Foreground="White" BorderThickness="0"
                                Padding="12,6" FontSize="12" FontWeight="Bold" Margin="0,0,8,0"/>
                        <Button Command="{Binding ImportCollectionCommand}" Content="_Import Collection (JSON)"
                                Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A4A"
                                BorderThickness="1" Padding="12,6" FontSize="12" Margin="0,0,8,0"/>
                        <Button Command="{Binding ExportCollectionWithFilesCommand}" Content="Export w/ _Files (ZIP)"
                                Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A4A"
                                BorderThickness="1" Padding="12,6" FontSize="12" Margin="0,0,8,0"/>
                        <Button Command="{Binding ImportCollectionWithFilesCommand}" Content="Import w/ _Files (ZIP)"
                                Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A4A"
                                BorderThickness="1" Padding="12,6" FontSize="12"/>
                    </StackPanel>

                    <TextBlock Text="{Binding CollectionStatus}" FontSize="12" Foreground="#CCCCCC" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
