<UserControl x:Class="EVO.ModManager.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EVO.ModManager.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BytesToSizeConverter x:Key="BytesSize"/>
    </UserControl.Resources>
    <ScrollViewer Background="Transparent" BorderThickness="0">
        <StackPanel Margin="24">
            <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Foreground="#E94560" Margin="0,0,0,20"/>

            <Border Background="#161640" BorderBrush="#1E1E4A" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Game Paths" FontSize="15" FontWeight="SemiBold" Foreground="#E0E0F0" Margin="0,0,0,10"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/><ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Game:" FontSize="13" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding GamePath}" FontSize="13" Foreground="#C0C0E0" Margin="10,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="ACE Folder:" FontSize="13" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AcePath}" FontSize="13" Foreground="#C0C0E0" Margin="10,0,0,6"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Editor SDK:" FontSize="13" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SdkStatus}" FontSize="13" Foreground="#C0C0E0" TextWrapping="Wrap" Margin="10,0,0,6"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="LiveryLab:" FontSize="13" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0">
                            <TextBlock Text="{Binding LiveryLabStatus}" FontSize="13" Foreground="#C0C0E0" TextWrapping="Wrap" VerticalAlignment="Center"/>
                            <Button Command="{Binding DownloadLiveryLabCommand}" Content="Download"
                                    Background="#1A1A3E" Foreground="#C0C0E0" BorderBrush="#2A2A5A"
                                    BorderThickness="1" Padding="10,5" FontSize="12" Cursor="Hand" Margin="10,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="#161640" BorderBrush="#1E1E4A" BorderThickness="1"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Storage Locations" FontSize="15" FontWeight="SemiBold" Foreground="#E0E0F0" Margin="0,0,0,8"/>
                    <TextBlock Text="Mods installed to external drives use symbolic links." FontSize="13" Foreground="#6666AA" TextWrapping="Wrap" Margin="0,0,0,14"/>

                    <ItemsControl ItemsSource="{Binding StorageLocations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#1A1A44" CornerRadius="6" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" Foreground="#E0E0F0"/>
                                                <Border Background="#2ECC71" CornerRadius="3" Padding="4,1" Margin="8,0,0,0"
                                                        Visibility="{Binding IsDefault, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="Default" FontSize="9" Foreground="White"/>
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Path}" FontSize="12" Foreground="#6666AA" Margin="0,2,0,0"/>
                                            <TextBlock Text="{Binding FreeSpace, StringFormat=Free: {0}}" FontSize="12" Foreground="#6666AA" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <Button Grid.Column="1" Content="Set Default" FontSize="12"
                                                Padding="8,4" Margin="6,0"
                                                Background="#1A1A3E" Foreground="#C0C0E0" BorderBrush="#2A2A5A"
                                                BorderThickness="1" Cursor="Hand"
                                                Command="{Binding DataContext.SetDefaultLocationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                        <Button Grid.Column="2" Content="Remove" FontSize="12"
                                                Padding="8,4" Margin="6,0"
                                                Background="#2E1E1E" Foreground="#E06060" BorderBrush="#3E2E2E"
                                                BorderThickness="1" Cursor="Hand"
                                                Command="{Binding DataContext.RemoveLocationCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Background="#1E1E4A" Margin="0,14,0,14" Opacity="0.5"/>

                    <TextBlock Text="Add New Storage" FontSize="14" FontWeight="SemiBold" Foreground="#E0E0F0" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontSize="13" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewLocationName, Mode=TwoWay}"
                                 Background="#1A1A3E" Foreground="#E0E0F0" BorderBrush="#2A2A5A"
                                 BorderThickness="1" Padding="8,4" FontSize="13" Margin="8,0,0,6"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Path:" FontSize="13" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewLocationPath, Mode=TwoWay}"
                                 Background="#1A1A3E" Foreground="#E0E0F0" BorderBrush="#2A2A5A"
                                 BorderThickness="1" Padding="8,4" FontSize="13" Margin="8,0,0,6"/>
                        <Button Grid.Row="1" Grid.Column="2" Command="{Binding BrowseLocationCommand}"
                                Content="Browse..." Background="#1A1A3E" Foreground="#C0C0E0"
                                BorderBrush="#2A2A5A" BorderThickness="1" Padding="10,4" FontSize="12"
                                Cursor="Hand" Margin="6,0,0,6"/>
                        <Button Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                Command="{Binding AddLocationCommand}" Content="Add Location"
                                Background="#E94560" Foreground="White" BorderThickness="0"
                                Padding="12,6" FontSize="13" FontWeight="SemiBold" Cursor="Hand"
                                HorizontalAlignment="Left" Margin="8,4,0,0"/>
                    </Grid>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#2ECC71" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
