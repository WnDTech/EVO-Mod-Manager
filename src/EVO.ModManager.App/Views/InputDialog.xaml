<Window x:Class="EVO.ModManager.App.Views.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Install from URL"
        Width="480" Height="180"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#0D0D1A" Foreground="#CCCCCC"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E1E40"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#2A2A50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A5A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A3A7A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Enter the URL of a mod archive (.zip, .7z, .rar, .kspkg):"
                   FontSize="12" Foreground="#AAAAAA" Margin="0,0,0,8"/>
        <Border Grid.Row="1" Background="#1A1A3E" BorderBrush="#2A2A50" BorderThickness="1" CornerRadius="4">
            <TextBox x:Name="UrlTextBox"
                     Background="Transparent" Foreground="#CCCCCC"
                     BorderThickness="0" FontSize="13"
                     Padding="10,4" VerticalContentAlignment="Center"
                     Text="" KeyDown="UrlTextBox_KeyDown"/>
        </Border>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Width="80" IsCancel="True" Margin="0,0,8,0"/>
            <Button x:Name="OkButton" Content="OK" Width="80" IsDefault="True"
                    Background="#E94560" Foreground="White" BorderThickness="0"
                    Click="OkButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
