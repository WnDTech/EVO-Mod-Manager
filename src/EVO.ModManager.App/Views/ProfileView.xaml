<UserControl x:Class="EVO.ModManager.App.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EVO.ModManager.App.Converters"
             Background="#0D0D1A" Foreground="#CCCCCC">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#141430" BorderBrush="#1E1E3E" BorderThickness="1"
                CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="New Profile" FontSize="12" Foreground="#6666AA" FontWeight="SemiBold" Margin="0,0,0,8"/>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center"/>
                        <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding NewProfileName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#181838" Foreground="#CCCCCC" BorderBrush="#2A2A50"
                                 Padding="6,3" FontSize="12" Margin="6,0,0,4"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Description:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center" Margin="0,4,0,0"/>
                        <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding NewProfileDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Background="#181838" Foreground="#CCCCCC" BorderBrush="#2A2A50"
                                 Padding="6,3" FontSize="12" Margin="6,4,0,0"/>
                        <Button Grid.Row="0" Grid.RowSpan="2" Grid.Column="2"
                                Command="{Binding CreateProfileCommand}"
                                Background="#E94560" Foreground="White" BorderThickness="0"
                                Padding="16,8" FontSize="12" FontWeight="Bold"
                                Content="_Create" Margin="10,0,0,0" VerticalAlignment="Center" Cursor="Hand"/>
                    </Grid>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                    <Button Command="{Binding LoadProfilesCommand}" Content="_Refresh"
                            Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A50"
                            BorderThickness="1" Padding="12,4" FontSize="12" Height="28"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#141430" BorderBrush="#1E1E3E"
                    BorderThickness="1" CornerRadius="8">
                <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="{Binding Description, TargetNullValue='No description'}" FontSize="11" Foreground="#6666AA" TextTrimming="CharacterEllipsis" MaxWidth="260"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                            <TextBlock Text="Created:" FontSize="10" Foreground="#5555AA"/>
                                            <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" FontSize="10" Foreground="#5555AA" Margin="4,0,0,0"/>
                                            <TextBlock Text=" · " FontSize="10" Foreground="#5555AA"/>
                                            <TextBlock FontSize="10" Foreground="#5555AA">
                                                <Run Text="{Binding ModEntries.Count}"/>
                                                <Run Text=" mod(s)"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" Background="#141430" BorderBrush="#1E1E3E"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel DataContext="{Binding SelectedProfile}">
                    <TextBlock Text="PROFILE DETAILS" FontSize="9" Foreground="#5555AA" FontWeight="Bold"/>

                    <Border Background="#181838" CornerRadius="6" Padding="14" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding Name, TargetNullValue='No profile selected'}" FontSize="15"
                                       FontWeight="SemiBold" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                            <Separator Background="#1E1E3E" Margin="0,8,0,8" Opacity="0.5"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Description:" FontSize="11" Foreground="#6666AA"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Description, TargetNullValue='—'}"
                                           FontSize="11" Foreground="#BBBBCC" TextWrapping="Wrap" Margin="6,0,0,4"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Created:" FontSize="11" Foreground="#6666AA" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" FontSize="11" Foreground="#BBBBCC" Margin="6,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Mods:" FontSize="11" Foreground="#6666AA" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Foreground="#BBBBCC" Margin="6,4,0,0">
                                    <Run Text="{Binding ModEntries.Count}"/>
                                    <Run Text=" mod(s) in profile"/>
                                </TextBlock>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="ID:" FontSize="11" Foreground="#6666AA" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Id, TargetNullValue='—'}" FontSize="11" Foreground="#555588" Margin="6,4,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel Margin="0,10,0,0">
                        <Button Command="{Binding DataContext.ActivateProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Background="#E94560" Foreground="White" BorderThickness="0"
                                Padding="12,7" FontSize="12" FontWeight="Bold"
                                HorizontalAlignment="Stretch" Content="▶ _Activate Profile" Cursor="Hand"/>
                        <Button Command="{Binding DataContext.DeleteProfileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Background="#1E1E40" Foreground="#E06060" BorderBrush="#2A2A50" BorderThickness="1"
                                Padding="12,6" FontSize="12" HorizontalAlignment="Stretch" Margin="0,6,0,0"
                                Content="_Delete Profile" Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock Text="{Binding DataContext.StatusText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                               FontSize="11" Foreground="#6666AA" Margin="0,10,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
