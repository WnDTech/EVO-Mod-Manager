<Window x:Class="EVO.ModManager.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EVO.ModManager.App.Converters"
        Title="EVO Mod Manager"
        Width="1280" Height="820"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="OnDrop"
        Background="#0D0D1A" Foreground="#DDDDDD">

    <Window.Resources>
        <conv:ModTypeToIconConverter x:Key="ModTypeIcon"/>
        <conv:BoolToStatusTextConverter x:Key="StatusText"/>
        <conv:BoolToToggleTextConverter x:Key="ToggleText"/>
        <conv:BytesToSizeConverter x:Key="BytesSize"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#12122A" BorderBrush="#1E1E3E" BorderThickness="0,0,0,1" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" VerticalAlignment="Center" FontSize="18" FontWeight="Bold">
                    <Run Text="ACE" Foreground="#E94560"/><Run Text=" Mod Manager" Foreground="#9999BB"/>
                </TextBlock>
                <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Width="240" Height="28" Background="#1A1A3E" Foreground="#DDDDDD" BorderBrush="#2A2A4A"
                         BorderThickness="1" FontSize="12" Padding="8,0" HorizontalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="_Browse" Command="{Binding OpenBrowseCommand}"
                            Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A4A"
                            BorderThickness="1" Padding="12,4" FontSize="12" Margin="0,0,8,0"/>
                    <Button Content="▶ _Play" Command="{Binding LaunchGameCommand}"
                            Background="#E94560" Foreground="White" BorderThickness="0"
                            Padding="14,5" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#12122A" BorderBrush="#1E1E3E" BorderThickness="0,0,1,0" Padding="0,12">
                <StackPanel>
                    <Border Background="#1A1A3E" Height="72" Margin="12,0,12,16" CornerRadius="6"
                            BorderBrush="#2A2A4A" BorderThickness="1">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Drop mods here" FontSize="10" Foreground="#666688" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="MANAGE" FontSize="9" Foreground="#555577" Margin="16,0,0,4" FontWeight="Bold"/>
                    <Button Content="Installed _Mods" Command="{Binding NavigateToModsCommand}"
                            Background="#1E1E3E" Foreground="#DDDDDD" BorderThickness="0" Padding="16,6" FontSize="12"
                            HorizontalContentAlignment="Left" Cursor="Hand"/>
                    <Button Content="_Browse Mods" Command="{Binding OpenBrowseCommand}"
                            Background="Transparent" Foreground="#9999BB" BorderThickness="0" Padding="16,6" FontSize="12"
                            HorizontalContentAlignment="Left" Cursor="Hand"/>
                    <Button Content="_Profiles"
                            Background="Transparent" Foreground="#9999BB" BorderThickness="0" Padding="16,6" FontSize="12"
                            HorizontalContentAlignment="Left" Cursor="Hand"/>

                    <TextBlock Text="TOOLS" FontSize="9" Foreground="#555577" Margin="16,12,0,4" FontWeight="Bold"/>
                    <Button Content="ACE _Editor" Command="{Binding LaunchEditorCommand}" IsEnabled="{Binding IsEditorAvailable}"
                            Background="Transparent" Foreground="#9999BB" BorderThickness="0" Padding="16,6" FontSize="12"
                            HorizontalContentAlignment="Left" Cursor="Hand"/>
                    <Button Content="_Settings" Command="{Binding OpenSettingsCommand}"
                            Background="Transparent" Foreground="#9999BB" BorderThickness="0" Padding="16,6" FontSize="12"
                            HorizontalContentAlignment="Left" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#0D0D1A">
                <Grid>
                    <Grid Visibility="{Binding IsModsViewVisible, Converter={StaticResource BoolVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                        <ScrollViewer Grid.Column="0" Margin="16,16,8,16" Background="Transparent" BorderThickness="0"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredMods}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="220" Height="148" Margin="0,0,10,10" Background="#16163A"
                                                CornerRadius="8" BorderBrush="#1E1E3E" BorderThickness="1"
                                                Cursor="Hand" MouseDown="ModCard_MouseDown">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="28"/>
                                                    <RowDefinition Height="*"/>
                                                    <RowDefinition Height="22"/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Background="#1A1A44"
                                                        CornerRadius="8,8,0,0" Padding="10,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding ModType, Converter={StaticResource ModTypeIcon}}" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding ModType}" FontSize="9" Foreground="#6666AA" VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                        <Border Grid.Column="2" CornerRadius="3" Padding="5,1" Height="16" VerticalAlignment="Center">
                                                            <Border.Background>
                                                                <SolidColorBrush Color="{Binding IsEnabled, Converter={StaticResource StatusColor}}"/>
                                                            </Border.Background>
                                                            <TextBlock Text="{Binding IsEnabled, Converter={StaticResource StatusText}}" FontSize="8" Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="10,6">
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="#DDDDDD" TextTrimming="CharacterEllipsis" MaxHeight="28" LineHeight="14"/>
                                                    <TextBlock Text="{Binding Author, TargetNullValue='Unknown'}" FontSize="10" Foreground="#6666AA" Margin="0,2,0,0"/>
                                                    <TextBlock Text="{Binding SizeBytes, Converter={StaticResource BytesSize}}" FontSize="10" Foreground="#5555AA" Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <Border Grid.Row="2" Padding="8,0" BorderBrush="#1E1E3E" BorderThickness="0,1,0,0">
                                                    <Grid>
                                                        <TextBlock Text="{Binding Version, TargetNullValue='—'}" FontSize="9" Foreground="#6666AA"/>
                                                        <TextBlock Text="{Binding IsSymlinked}" FontSize="9" Foreground="#6666AA" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Border Grid.Column="1" Margin="0,16,16,16" Background="#16163A"
                                CornerRadius="8" BorderBrush="#1E1E3E" BorderThickness="1" Padding="16">
                            <StackPanel>
                                <TextBlock Text="DETAILS" FontSize="9" Foreground="#5555AA" FontWeight="Bold"/>
                                <Border Background="#1A1A44" CornerRadius="6" Margin="0,10,0,0" Padding="14" MinHeight="160">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedMod.Name, TargetNullValue='No mod selected'}"
                                                   FontSize="14" FontWeight="Bold" Foreground="#DDDDDD" TextWrapping="Wrap"/>
                                        <TextBlock Text="{Binding SelectedMod.FileName, TargetNullValue=''}"
                                                   FontSize="10" Foreground="#6666AA" Margin="0,4,0,10"/>
                                        <Separator Background="#1E1E3E" Margin="0,0,0,10"/>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/><ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Type" FontSize="11" Foreground="#6666AA"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedMod.ModType}" FontSize="12" Foreground="#BBBBCC"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Version" FontSize="11" Foreground="#6666AA" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedMod.Version, TargetNullValue='—'}" FontSize="12" Foreground="#BBBBCC" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Author" FontSize="11" Foreground="#6666AA" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedMod.Author, TargetNullValue='—'}" FontSize="12" Foreground="#BBBBCC" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Size" FontSize="11" Foreground="#6666AA" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedMod.SizeBytes, Converter={StaticResource BytesSize}}" FontSize="12" Foreground="#BBBBCC" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Status" FontSize="11" Foreground="#6666AA" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="4" Grid.Column="1" FontSize="12" Foreground="#BBBBCC" Margin="0,5,0,0">
                                                <Run Text="{Binding SelectedMod.IsEnabled, Converter={StaticResource StatusText}}"/>
                                            </TextBlock>
                                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Symlink" FontSize="11" Foreground="#6666AA" Margin="0,5,0,0"/>
                                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding SelectedMod.IsSymlinked}" FontSize="12" Foreground="#BBBBCC" Margin="0,5,0,0"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                <Button Command="{Binding ToggleModCommand}" CommandParameter="{Binding SelectedMod}"
                                        Background="#E94560" Foreground="White" BorderThickness="0"
                                        Padding="12,7" FontSize="12" FontWeight="Bold"
                                        HorizontalAlignment="Stretch" Margin="0,10,0,0" Cursor="Hand">
                                    <TextBlock>
                                        <Run Text="{Binding SelectedMod.IsEnabled, Converter={StaticResource ToggleText}}"/>
                                        <Run Text=" Mod"/>
                                    </TextBlock>
                                </Button>
                                <Button Command="{Binding DeleteModCommand}" CommandParameter="{Binding SelectedMod}"
                                        Background="#2A2A4A" Foreground="#E06060" BorderBrush="#3E3E5E"
                                        BorderThickness="1" Padding="12,6" FontSize="12" Cursor="Hand"
                                        HorizontalAlignment="Stretch" Margin="0,6,0,0" Content="_Delete"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <ContentControl Content="{Binding SettingsView}" Visibility="{Binding IsSettingsViewVisible, Converter={StaticResource BoolVis}}"/>
                    <ContentControl Content="{Binding BrowseView}" Visibility="{Binding IsBrowseViewVisible, Converter={StaticResource BoolVis}}"/>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#0A0A1A" BorderBrush="#1E1E3E" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" FontSize="10" Foreground="#666688">
                    <Run Text="{Binding ModCount}"/><Run Text=" mods installed"/>
                </TextBlock>
                <TextBlock Grid.Column="1" FontSize="10" Foreground="#666688" HorizontalAlignment="Center" Text="{Binding StatusText}"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock FontSize="10" Foreground="#E94560" Visibility="{Binding IsEditorAvailable, Converter={StaticResource BoolVis}}" Margin="0,0,12,0">SDK ✓</TextBlock>
                    <TextBlock FontSize="10" Foreground="#F39C12">
                        <Run Text="{Binding ConflictCount}"/><Run Text=" conflicts"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
