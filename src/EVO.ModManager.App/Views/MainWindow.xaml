<Window x:Class="EVO.ModManager.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:EVO.ModManager.App.Converters"
        Title="EVO Mod Manager"
        Width="1280" Height="820"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True"
        Drop="OnDrop"
        Background="#0D0D1A"
        TextOptions.TextFormattingMode="Display"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <Window.Resources>
        <conv:ModTypeToIconConverter x:Key="ModTypeIcon"/>
        <conv:BoolToStatusTextConverter x:Key="StatusText"/>
        <conv:BoolToToggleTextConverter x:Key="ToggleText"/>
        <conv:BoolToStatusColorConverter x:Key="StatusColor"/>
        <conv:BytesToSizeConverter x:Key="BytesSize"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#8888AA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1A1A3E"/>
                    <Setter Property="Foreground" Value="#EAEAEA"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#E94560"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1E1E3A"/>
            <Setter Property="Foreground" Value="#C0C0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A2A4A"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="52"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0" Background="#12122A"
                BorderBrush="#1E1E3E" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="EVO" FontSize="20" FontWeight="Bold"
                               Foreground="#E94560" VerticalAlignment="Center"/>
                    <TextBlock Text="Mod Manager" FontSize="20" FontWeight="SemiBold"
                               Foreground="#C0C0E0" VerticalAlignment="Center" Margin="2,0,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border Background="#1A1A3E" CornerRadius="6" Height="32"
                            BorderBrush="#2A2A4A" BorderThickness="1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="12"
                                       VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <TextBox Grid.Column="1" Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="#C0C0E0"
                                     BorderThickness="0" VerticalAlignment="Center"
                                     FontSize="12" Padding="8,0"/>
                        </Grid>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"
                            Command="{Binding OpenBrowseCommand}" Content="Browse"/>
                    <Button x:Name="PlayButton" Style="{StaticResource PrimaryButton}"
                            Command="{Binding LaunchGameCommand}"
                            Content="▶  Play"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="#12122A"
                    BorderBrush="#1E1E3E" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Drop Zone -->
                    <Border Grid.Row="0" Background="#1A1A3E" Margin="12,12"
                            CornerRadius="8" BorderBrush="#2A2A4A" BorderThickness="2" Height="80">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center"/>
                            <TextBlock Text="Drop mods here" FontSize="10"
                                       Foreground="#666688" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Nav Items -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="MANAGE" FontSize="9" Foreground="#555577"
                                   Margin="16,0,0,4" FontWeight="SemiBold"/>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding NavigateToModsCommand}" Content="📦  Mods"/>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding OpenBrowseCommand}" Content="🌐  Download"/>
                        <Button Style="{StaticResource SidebarButton}" Content="📋  Profiles"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" VerticalAlignment="Bottom" Margin="0,0,0,8">
                        <TextBlock Text="TOOLS" FontSize="9" Foreground="#555577"
                                   Margin="16,0,0,4" FontWeight="SemiBold"/>
                        <Button Style="{StaticResource SidebarButton}"
                                IsEnabled="{Binding IsEditorAvailable}"
                                Command="{Binding LaunchEditorCommand}"
                                Content="🔧  ACE Editor"/>
                        <Button Style="{StaticResource SidebarButton}"
                                Command="{Binding OpenSettingsCommand}"
                                Content="⚙  Settings"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- CONTENT PANEL -->
            <Border Grid.Column="1" Background="#0D0D1A" Padding="0">
                <Grid>
                    <!-- Mods List View -->
                    <Grid Visibility="{Binding IsModsViewVisible}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="340" MinWidth="280"/>
                        </Grid.ColumnDefinitions>

                        <!-- Mod Grid -->
                        <ScrollViewer Grid.Column="0" Margin="16,16,8,16"
                                      Background="Transparent" BorderThickness="0">
                        <ItemsControl ItemsSource="{Binding FilteredMods}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="220" Height="160" Margin="0,0,12,12"
                                            Background="#161630" CornerRadius="10"
                                            BorderBrush="#1E1E3E" BorderThickness="1"
                                            Cursor="Hand"
                                            MouseDown="ModCard_MouseDown">
                                        <Grid Margin="0">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Card header: type icon + status -->
                                            <Border Grid.Row="0" Background="#1A1A3E"
                                                    CornerRadius="10,10,0,0" Padding="12,8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0"
                                                        Text="{Binding ModType, Converter={StaticResource ModTypeIcon}}"
                                                        FontSize="16"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding ModType}"
                                                               FontSize="10" Foreground="#666688"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <Border Grid.Column="2" CornerRadius="4" Padding="6,2"
                                                            Background="{Binding IsEnabled, Converter={StaticResource StatusColor}}">
                                                        <TextBlock Text="{Binding IsEnabled, Converter={StaticResource StatusText}}"
                                                                   FontSize="9" Foreground="White" FontWeight="SemiBold"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Card body -->
                                            <StackPanel Grid.Row="1" Margin="12,8">
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           FontWeight="SemiBold" Foreground="#EAEAEA"
                                                           TextTrimming="CharacterEllipsis"
                                                           MaxHeight="36" LineHeight="18"/>
                                                <TextBlock Text="{Binding Author, TargetNullValue='Unknown'}"
                                                           FontSize="11" Foreground="#555577"
                                                           Margin="0,2,0,0"/>
                                                <TextBlock Text="{Binding SizeBytes, Converter={StaticResource BytesSize}}"
                                                           FontSize="10" Foreground="#444466"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Card footer -->
                                            <Border Grid.Row="2" Padding="8,6"
                                                    BorderBrush="#1E1E3E" BorderThickness="0,1,0,0">
                                                <Grid>
                                                    <TextBlock Text="{Binding Version, TargetNullValue='v1.0'}"
                                                               FontSize="10" Foreground="#555577"/>
                                                    <TextBlock Text="{Binding IsSymlinked, StringFormat='🔗 {0}'}"
                                                               FontSize="10" Foreground="#555577"
                                                               HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Detail Panel -->
                    <Border Grid.Column="1" Margin="0,16,16,16"
                            Background="#161630" CornerRadius="12"
                            BorderBrush="#1E1E3E" BorderThickness="1" Padding="20">
                        <StackPanel DataContext="{Binding SelectedMod}">
                            <!-- Header with close/thumbs -->
                            <Grid>
                                <TextBlock Text="Mod Details" FontSize="11"
                                           Foreground="#555577" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </Grid>

                            <Border Background="#1A1A3E" CornerRadius="10" Margin="0,12,0,0"
                                    Padding="16" MinHeight="200">
                                <StackPanel VerticalAlignment="Top">
                                    <TextBlock Text="{Binding Name, TargetNullValue='Select a mod'}"
                                               FontSize="16" FontWeight="Bold" Foreground="#EAEAEA"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="11"
                                               Foreground="#444466" Margin="0,4,0,12"/>

                                    <Separator Background="#1E1E3E" Margin="0,0,0,12"/>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Type" FontSize="11" Foreground="#555577"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="{Binding ModType}" FontSize="12" Foreground="#C0C0E0"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0"
                                                   Text="Version" FontSize="11" Foreground="#555577" Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1"
                                                   Text="{Binding Version, TargetNullValue='-'}" FontSize="12"
                                                   Foreground="#C0C0E0" Margin="0,6,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Author" FontSize="11" Foreground="#555577" Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="{Binding Author, TargetNullValue='-'}" FontSize="12"
                                                   Foreground="#C0C0E0" Margin="0,6,0,0"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0"
                                                   Text="Size" FontSize="11" Foreground="#555577" Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1"
                                                   Text="{Binding SizeBytes, Converter={StaticResource BytesSize}}" FontSize="12"
                                                   Foreground="#C0C0E0" Margin="0,6,0,0"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0"
                                                   Text="Status" FontSize="11" Foreground="#555577" Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" FontSize="12"
                                                   Foreground="#C0C0E0" Margin="0,6,0,0">
                                            <Run Text="{Binding IsEnabled, Converter={StaticResource StatusText}}"/>
                                        </TextBlock>

                                        <TextBlock Grid.Row="5" Grid.Column="0"
                                                   Text="Symlink" FontSize="11" Foreground="#555577" Margin="0,6,0,0"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1"
                                                   Text="{Binding IsSymlinked}" FontSize="12"
                                                   Foreground="#C0C0E0" Margin="0,6,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Action buttons -->
                            <StackPanel Margin="0,12,0,0" DataContext="{Binding SelectedMod}">
                                <Button Style="{StaticResource PrimaryButton}"
                                        Command="{Binding DataContext.ToggleModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" HorizontalAlignment="Stretch">
                                    <TextBlock>
                                        <Run Text="{Binding IsEnabled, Converter={StaticResource ToggleText}}"/>
                                        <Run Text=" Mod"/>
                                    </TextBlock>
                                </Button>
                                <Button Style="{StaticResource SecondaryButton}" Margin="0,8,0,0"
                                        Command="{Binding DataContext.DeleteModCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}" HorizontalAlignment="Stretch"
                                        Foreground="#E74C3C" Content="Delete Mod"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Settings View -->
                <ContentControl Content="{Binding SettingsView}" Visibility="{Binding IsSettingsViewVisible}"/>
                <ContentControl Content="{Binding BrowseView}" Visibility="{Binding IsBrowseViewVisible}"/>
            </Grid>
        </Border>
    </Grid>

    <Border Grid.Row="2" Background="#0A0A1A"
                BorderBrush="#1E1E3E" BorderThickness="0,1,0,0" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Foreground="#555577" FontSize="11">
                    <Run Text="{Binding ModCount}"/><Run Text=" mods installed"/>
                </TextBlock>

                <TextBlock Grid.Column="1" Foreground="#555577" FontSize="11"
                           HorizontalAlignment="Center" Text="{Binding StatusText}"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Foreground="#E94560" FontSize="11" FontWeight="SemiBold"
                               Visibility="{Binding IsEditorAvailable, Converter={StaticResource BoolVis}}"
                               Margin="0,0,12,0">SDK ✓</TextBlock>
                    <TextBlock Foreground="#F39C12" FontSize="11" FontWeight="SemiBold">
                        <Run Text="{Binding ConflictCount, Mode=OneWay}"/><Run Text=" conflicts"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
