<UserControl x:Class="EVO.ModManager.App.Views.BrowseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EVO.ModManager.App.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#141430" BorderBrush="#1E1E40"
                BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="Source:" FontSize="11" Foreground="#555580"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding Sources}"
                                      SelectedItem="{Binding SelectedSource}"
                                      DisplayMemberPath="Name"
                                      Width="140" VerticalAlignment="Center"
                                      Background="#1E1E40" Foreground="#BBBBE0"
                                      BorderBrush="#2E2E58" BorderThickness="1"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Category:" FontSize="11" Foreground="#555580"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <ComboBox ItemsSource="{Binding Categories}"
                                      SelectedItem="{Binding SelectedCategory}"
                                      Width="120" VerticalAlignment="Center"
                                      Background="#1E1E40" Foreground="#BBBBE0"
                                      BorderBrush="#2E2E58" BorderThickness="1"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Command="{Binding FetchModsCommand}" Content="Refresh"
                                Background="#1E1E40" Foreground="#BBBBE0" BorderBrush="#2E2E58"
                                BorderThickness="1" Padding="12,6" FontSize="11" Cursor="Hand"/>
                        <Border Background="#181838" CornerRadius="4" Padding="10,4"
                                VerticalAlignment="Center" Margin="8,0,0,0"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="Loading..." Foreground="#555580" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Grid>

                <Border Background="#181838" CornerRadius="4" Padding="12,6" Margin="0,8,0,0"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar Grid.Column="0" Value="{Binding DownloadProgress}"
                                     Height="14" Foreground="#2ECC71" Background="#0B0B1A"
                                     BorderBrush="#1C1C40" BorderThickness="1" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="10"
                                   Foreground="#555580" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#141430" BorderBrush="#1E1E40"
                    BorderThickness="1" CornerRadius="8">
                <ListBox ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10,8" CornerRadius="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#DDDDF0"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Author, TargetNullValue='Unknown'}"
                                                       FontSize="10" Foreground="#555580"/>
                                            <TextBlock Text=" · " FontSize="10" Foreground="#444470"/>
                                            <TextBlock Text="{Binding Published, StringFormat={}{0:yyyy-MM-dd}}"
                                                       FontSize="10" Foreground="#555580"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#1E1E40" CornerRadius="3"
                                            Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category, TargetNullValue='Mod'}"
                                                   FontSize="9" Foreground="#555580"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Margin="12,0,0,0" Background="#141430"
                    BorderBrush="#1E1E40" BorderThickness="1" CornerRadius="8" Padding="14">
                <StackPanel>
                    <TextBlock Text="Preview" FontSize="9" Foreground="#444470" FontWeight="Bold"/>
                    <Border Margin="0,10,0,0" Background="#181838" BorderBrush="#1C1C40"
                            BorderThickness="1" CornerRadius="6" Padding="12" MinHeight="180"
                            DataContext="{Binding SelectedMod}">
                        <StackPanel>
                            <TextBlock Text="{Binding Title, TargetNullValue='Select a mod'}"
                                       FontSize="13" FontWeight="Bold" Foreground="#DDDDF0"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Description, TargetNullValue=''}"
                                       FontSize="10" Foreground="#555580" TextWrapping="Wrap"
                                       MaxHeight="140" Margin="0,6,0,0"/>
                            <Separator Background="#1C1C40" Margin="0,8,0,8" Opacity="0.5"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="65"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Author:" FontSize="10" Foreground="#555580"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Author}" FontSize="10" Foreground="#BBBBE0"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Date:" FontSize="10" Foreground="#555580" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Published, StringFormat={}{0:yyyy-MM-dd}}" FontSize="10" Foreground="#BBBBE0" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" FontSize="10" Foreground="#555580" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}" FontSize="10" Foreground="#BBBBE0" Margin="0,4,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Button Command="{Binding DataContext.DownloadSelectedCommand,
                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Background="#E94560" Foreground="White" BorderThickness="0"
                            Padding="12,7" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                            HorizontalAlignment="Stretch" Margin="0,10,0,0" Content="Download &amp; Install"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
