<UserControl x:Class="EVO.ModManager.App.Views.BrowseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:EVO.ModManager.App.Converters"
             Background="#0D0D1A" Foreground="#CCCCCC">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#1A1A3E"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,4"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A5A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#3A3A7A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#16163A" BorderBrush="#1E1E3E" BorderThickness="1"
                CornerRadius="8" Padding="16" Margin="0,0,0,12">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                            <TextBlock Text="Source:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}"
                                      DisplayMemberPath="Name" Width="150" Height="28"
                                      Background="#1A1A3E" Foreground="#CCCCCC" BorderBrush="#2A2A50" FontSize="12"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Category:" FontSize="12" Foreground="#6666AA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox ItemsSource="{Binding Categories}" SelectedItem="{Binding SelectedCategory}" DisplayMemberPath="Name"
                                      Width="130" Height="28"
                                      Background="#1A1A3E" Foreground="#CCCCCC" BorderBrush="#2A2A50" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Command="{Binding FetchModsCommand}" Content="Refresh"
                            Background="#1E1E3E" Foreground="#CCCCCC" BorderBrush="#2A2A50"
                            BorderThickness="1" Padding="12,4" FontSize="12" Height="28"/>
                </Grid>
                <Border Background="#1A1A3E" CornerRadius="4" Padding="12,6" Margin="0,8,0,0"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ProgressBar Value="{Binding DownloadProgress}" Height="14"
                                     Foreground="#2ECC71" Background="#0D0D1A"
                                     BorderBrush="#1E1E3E" BorderThickness="1"/>
                        <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="11"
                                   Foreground="#6666AA" Margin="10,0,0,0" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </StackPanel>
        </Border>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Background="#16163A" BorderBrush="#1E1E3E"
                    BorderThickness="1" CornerRadius="8">
                <ListBox ItemsSource="{Binding Mods}" SelectedItem="{Binding SelectedMod}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/><ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="#CCCCCC"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <TextBlock Text="{Binding Author, TargetNullValue='Unknown'}" FontSize="11" Foreground="#6666AA"/>
                                            <TextBlock Text=" · " FontSize="11" Foreground="#555588"/>
                                            <TextBlock Text="{Binding Published, StringFormat={}{0:yyyy-MM-dd}}" FontSize="11" Foreground="#6666AA"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="#1A1A3E" CornerRadius="3"
                                            Padding="4,2" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Category, TargetNullValue='Mod'}" FontSize="10" Foreground="#6666AA"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
            <Border Grid.Column="1" Margin="12,0,0,0" Background="#16163A" BorderBrush="#1E1E3E"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel>
                    <TextBlock Text="PREVIEW" FontSize="9" Foreground="#5555AA" FontWeight="Bold"/>
                    <Border Margin="0,10,0,0" Background="#1A1A44" BorderBrush="#1E1E3E"
                            BorderThickness="1" CornerRadius="6" Padding="12" MinHeight="160">
                        <StackPanel DataContext="{Binding SelectedMod}">
                            <TextBlock Text="{Binding Title, TargetNullValue='No mod selected'}" FontSize="14"
                                       FontWeight="Bold" Foreground="#CCCCCC" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding Description, TargetNullValue=''}" FontSize="11"
                                       Foreground="#6666AA" TextWrapping="Wrap" MaxHeight="120" Margin="0,6,0,0"/>
                            <Separator Background="#1E1E3E" Margin="0,8,0,8" Opacity="0.5"/>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/><ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Author:" FontSize="11" Foreground="#6666AA"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Author}" FontSize="11" Foreground="#BBBBCC"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Date:" FontSize="11" Foreground="#6666AA" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Published, StringFormat={}{0:yyyy-MM-dd}}" FontSize="11" Foreground="#BBBBCC" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" FontSize="11" Foreground="#6666AA" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Category}" FontSize="11" Foreground="#BBBBCC" Margin="0,4,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <Button Command="{Binding DataContext.DownloadSelectedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            Background="#E94560" Foreground="White" BorderThickness="0"
                            Padding="12,7" FontSize="12" FontWeight="Bold"
                            HorizontalAlignment="Stretch" Margin="0,10,0,0" Content="Download &amp; Install"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>


